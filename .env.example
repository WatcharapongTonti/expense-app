# Environment Variables
# Copy this to .env.local and fill in the values

# Database (SQLite — path relative to project root)
DATABASE_URL="file:./dev.db"

# Session secret — must be at least 32 characters, keep this private!
SESSION_SECRET="change-me-to-a-random-32-char-string!!"

# LINE Messaging API credentials
# Get these from https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""

# LINE OA Basic ID (e.g. @abc1234xyz) — used for LINE deep links on the invite page
NEXT_PUBLIC_LINE_OA_BASIC_ID=""

# LINE LIFF (LINE Front-end Framework)
# 1. Create a LINE Login channel in LINE Developers Console
# 2. Add a LIFF app with endpoint URL: https://yourdomain.com/liff/link-group
# 3. Copy the LIFF ID (e.g. "1234567890-abcdefgh")
NEXT_PUBLIC_LIFF_ID=""
# Channel ID of the LINE Login channel the LIFF app belongs to (used for ID token verification)
LINE_LIFF_CHANNEL_ID=""
